{
  "ten": {
    "predefined_graphs": [
      {
        "name": "voice_assistant_live2d",
        "auto_start": true,
        "graph": {
          "nodes": [
            {
              "type": "extension",
              "name": "agora_rtc",
              "addon": "agora_rtc",
              "extension_group": "default",
              "property": {
                "app_id": "${env:AGORA_APP_ID}",
                "app_certificate": "${env:AGORA_APP_CERTIFICATE|}",
                "channel": "ten_agent_test",
                "stream_id": 1234,
                "remote_stream_id": 123,
                "subscribe_audio": true,
                "publish_audio": true,
                "publish_data": true,
                "enable_agora_asr": false
              }
            },
            {
              "type": "extension",
              "name": "stt",
              "addon": "deepgram_asr_python",
              "extension_group": "stt",
              "property": {
                "params": {
                  "api_key": "${env:DEEPGRAM_API_KEY}",
                  "language": "vi",
                  "model": "nova-3"
                }
              }
            },
            {
              "type": "extension",
              "name": "llm",
              "addon": "openai_llm2_python",
              "extension_group": "chatgpt",
              "property": {
                "base_url": "https://api.openai.com/v1",
                "api_key": "${env:OPENAI_API_KEY}",
                "frequency_penalty": 0.9,
                "model": "${env:OPENAI_MODEL}",
                "max_completion_tokens": 512,
                "prompt": "You are Kevin the Marmot, a warm Live2D Vietnamese general-purpose assistant for a local EV cockpit demo. Always understand and reply in tiếng Việt. You can help with ordinary assistant tasks such as conversation, explanations, brainstorming, planning, reminders, general Q&A, time/date questions, and light productivity support; car control is only one extra capability. Do not present car controls as your only capabilities. When asked what you can do, answer as a general-purpose assistant first, then briefly mention that you can also read and control the demo car dashboard. User input includes CURRENT_CAR_STATE JSON followed by USER_MESSAGE. Use CURRENT_CAR_STATE to answer status questions, for example if the user asks tốc độ quạt bây giờ là bao nhiêu, read climate.fan and reply with the current fan level. For every final answer, return only valid JSON with this shape: {\"reply\":\"short natural Vietnamese reply\",\"commands\":[{\"target\":\"climate.ac\",\"action\":\"set\",\"value\":true}]}. Do not wrap JSON in markdown. If the user is only chatting or asking status, use an empty commands array. Supported command targets are: climate.ac boolean, climate.temperature number 16-30, climate.fan number 0-5, media.volume number 0-100, media.playback boolean, navigation.destination string, lights.headlights boolean, lights.cabin boolean, locks.doors boolean where true means locked, windows.driver number 0-100, windows.passenger number 0-100. Execute safe demo commands immediately. Example: USER_MESSAGE tăng quạt lên mức 2 returns {\"reply\":\"Đã chỉnh quạt lên mức 2.\",\"commands\":[{\"target\":\"climate.fan\",\"action\":\"set\",\"value\":2}]}. When the user asks about the current time, today's date, or weekday, call get_current_datetime before answering, then still return the same JSON shape with an empty commands array. This demo only supports Vietnam time.",
                "proxy_url": "${env:OPENAI_PROXY_URL|}",
                "greeting": "Xin chào, mình là Kevin the Marmot. Mình có thể giúp gì cho bạn hôm nay?",
                "max_memory_length": 10
              }
            },
            {
              "type": "extension",
              "name": "tts",
              "addon": "senvoice_tts_python",
              "extension_group": "tts",
              "property": {
                "params": {
                  "base_url": "${env:SENVOICE_TTS_URL|https://senvoice-api.vizone.ai/tts-gateway-v2/v1/tts/sync/turbo}",
                  "key": "${env:SENVOICE_TTS_KEY}",
                  "voice": "${env:SENVOICE_TTS_VOICE|S_F03_ThuyDuyen}",
                  "speed": "${env:SENVOICE_TTS_SPEED|1}",
                  "lang": "${env:SENVOICE_TTS_LANGUAGE|vi}",
                  "sample_rate": "${env:SENVOICE_TTS_SAMPLE_RATE|44100}"
                }
              }
            },
            {
              "type": "extension",
              "name": "main_control",
              "addon": "main_python",
              "extension_group": "control",
              "property": {
                "greeting": "Xin chào, mình là Kevin the Marmot. Mình có thể giúp gì cho bạn hôm nay?"
              }
            },
            {
              "type": "extension",
              "name": "message_collector",
              "addon": "message_collector2",
              "extension_group": "transcriber",
              "property": {}
            },
            {
              "type": "extension",
              "name": "weatherapi_tool_python",
              "addon": "weatherapi_tool_python",
              "extension_group": "default",
              "property": {
                "api_key": "${env:WEATHERAPI_API_KEY|}"
              }
            },
            {
              "type": "extension",
              "name": "local_time_tool_python",
              "addon": "local_time_tool_python",
              "extension_group": "default",
              "property": {
                "timezone": "Asia/Ho_Chi_Minh",
                "locale": "vi-VN"
              }
            },
            {
              "type": "extension",
              "name": "streamid_adapter",
              "addon": "streamid_adapter",
              "property": {}
            },
            {
              "type": "extension",
              "name": "http_server_python",
              "addon": "http_server_python",
              "property": {
                "listen_port": 8070
              }
            }
          ],
          "connections": [
            {
              "extension": "main_control",
              "cmd": [
                {
                  "names": ["on_user_joined", "on_user_left"],
                  "source": [
                    {
                      "extension": "agora_rtc"
                    }
                  ]
                },
                {
                  "names": ["tool_register"],
                  "source": [
                    {
                      "extension": "weatherapi_tool_python"
                    },
                    {
                      "extension": "local_time_tool_python"
                    }
                  ]
                }
              ],
              "data": [
                {
                  "name": "asr_result",
                  "source": [
                    {
                      "extension": "stt"
                    }
                  ]
                }
              ]
            },
            {
              "extension": "agora_rtc",
              "audio_frame": [
                {
                  "name": "pcm_frame",
                  "dest": [
                    {
                      "extension": "streamid_adapter"
                    }
                  ]
                },
                {
                  "name": "pcm_frame",
                  "source": [
                    {
                      "extension": "tts"
                    }
                  ]
                }
              ],
              "data": [
                {
                  "name": "data",
                  "source": [
                    {
                      "extension": "message_collector"
                    }
                  ]
                }
              ]
            },
            {
              "extension": "streamid_adapter",
              "audio_frame": [
                {
                  "name": "pcm_frame",
                  "dest": [
                    {
                      "extension": "stt"
                    }
                  ]
                }
              ]
            }
            ,
            {
              "extension": "http_server_python",
              "cmd": [
                {
                  "names": ["http_cmd"],
                  "dest": [
                    {
                      "extension": "main_control"
                    }
                  ]
                }
              ],
              "data": [
                {
                  "name": "http_data",
                  "dest": [
                    {
                      "extension": "main_control"
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    ],
    "log": {
      "handlers": [
        {
          "matchers": [
            {
              "level": "info"
            }
          ],
          "formatter": {
            "type": "plain",
            "colored": true
          },
          "emitter": {
            "type": "console",
            "config": {
              "stream": "stdout"
            }
          }
        }
      ]
    }
  }
}
