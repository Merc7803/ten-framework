# Local environment files
*/frontend/.env
*/frontend/.env.local
*/frontend/.env.*.local
*/tenapp/.env

# Frontend generated files
*/frontend/node_modules/
*/frontend/.next/
*/frontend/out/
*/frontend/build/
*/frontend/dist/
*/frontend/*.tsbuildinfo
!*/frontend/src/lib/
!*/frontend/src/lib/**

# TEN/Go generated files
*/tenapp/bin/
*/tenapp/bin/main
*/tenapp/.ten/
*/tenapp/.cache/
*/tenapp/compile_commands.json

# Installed TEN packages generated by task install.
*/tenapp/ten_packages/addon_loader/
*/tenapp/ten_packages/system/
*/tenapp/ten_packages/extension/*
!*/tenapp/ten_packages/extension/main_python/
!*/tenapp/ten_packages/extension/main_python/**
!*/tenapp/ten_packages/extension/http_server_python/
!*/tenapp/ten_packages/extension/http_server_python/**

